{
  "$defs": {
    "AbstractionLayer": {
      "description": "Governance abstraction axis: how distilled an item is.",
      "enum": [
        "L0",
        "L1",
        "L2"
      ],
      "title": "AbstractionLayer",
      "type": "string"
    },
    "ContextViews": {
      "description": "Token-budgeted loading views for one memory item.\n\nlocator is used for recall, overview for structured context, and detail_uri\npoints at the canonical markdown body.",
      "properties": {
        "locator": {
          "default": "",
          "title": "Locator",
          "type": "string"
        },
        "overview": {
          "default": "",
          "title": "Overview",
          "type": "string"
        },
        "detail_uri": {
          "default": "",
          "title": "Detail Uri",
          "type": "string"
        }
      },
      "title": "ContextViews",
      "type": "object"
    },
    "DecayClass": {
      "enum": [
        "architecture",
        "decision",
        "fact",
        "episode",
        "ephemeral"
      ],
      "title": "DecayClass",
      "type": "string"
    },
    "Maturity": {
      "description": "Memory maturity axis: how trustworthy/reusable an item has become.",
      "enum": [
        "raw",
        "consolidated",
        "skill"
      ],
      "title": "Maturity",
      "type": "string"
    },
    "MemoryType": {
      "enum": [
        "fact",
        "episode",
        "decision",
        "artifact",
        "signal",
        "handoff",
        "policy",
        "skill"
      ],
      "title": "MemoryType",
      "type": "string"
    },
    "Refs": {
      "properties": {
        "files": {
          "items": {
            "type": "string"
          },
          "title": "Files",
          "type": "array"
        },
        "urls": {
          "items": {
            "type": "string"
          },
          "title": "Urls",
          "type": "array"
        },
        "mems": {
          "items": {
            "type": "string"
          },
          "title": "Mems",
          "type": "array"
        },
        "commits": {
          "items": {
            "type": "string"
          },
          "title": "Commits",
          "type": "array"
        },
        "resources": {
          "items": {
            "type": "string"
          },
          "title": "Resources",
          "type": "array"
        },
        "extractions": {
          "items": {
            "type": "string"
          },
          "title": "Extractions",
          "type": "array"
        }
      },
      "title": "Refs",
      "type": "object"
    },
    "Retention": {
      "properties": {
        "last_accessed": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Accessed"
        },
        "access_count": {
          "default": 0,
          "title": "Access Count",
          "type": "integer"
        },
        "decay_class": {
          "$ref": "#/$defs/DecayClass",
          "default": "fact"
        }
      },
      "title": "Retention",
      "type": "object"
    },
    "Sensitivity": {
      "enum": [
        "public",
        "internal",
        "private",
        "secret"
      ],
      "title": "Sensitivity",
      "type": "string"
    },
    "Source": {
      "description": "Provenance of how an item entered the pool (orthogonal to type/abstraction).\n\nUsed by the harvester for span-level dedup so the same transcript region is\nnever archived twice. Optional + defaulted → backward-compatible with 0.4 items.",
      "properties": {
        "kind": {
          "default": "manual",
          "title": "Kind",
          "type": "string"
        },
        "transcript_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Transcript Id"
        },
        "span_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Span Hash"
        },
        "extractor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extractor"
        }
      },
      "title": "Source",
      "type": "object"
    },
    "Validity": {
      "description": "Scope where a state observation was known to be valid.\n\nOptional + ignored-extra keeps old items loadable while letting newer\nruntime-state memories declare where they were observed.",
      "properties": {
        "observed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed At"
        },
        "ttl_hours": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ttl Hours"
        },
        "cwd": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cwd"
        },
        "repo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repo"
        },
        "branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Branch"
        },
        "os": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Os"
        },
        "adapter": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Adapter"
        }
      },
      "title": "Validity",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Memory item frontmatter schema — forward-only, no version numbering.",
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1",
      "title": "Schema Version",
      "type": "string"
    },
    "type": {
      "$ref": "#/$defs/MemoryType"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "agent": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Agent"
    },
    "session": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Session"
    },
    "project": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Project"
    },
    "tenant_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tenant Id"
    },
    "auth_context": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Auth Context"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "sensitivity": {
      "$ref": "#/$defs/Sensitivity",
      "default": "internal"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "summary": {
      "title": "Summary",
      "type": "string"
    },
    "refs": {
      "$ref": "#/$defs/Refs"
    },
    "confidence": {
      "default": 0.7,
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "retention": {
      "$ref": "#/$defs/Retention"
    },
    "abstraction": {
      "$ref": "#/$defs/AbstractionLayer",
      "default": "L0"
    },
    "maturity": {
      "$ref": "#/$defs/Maturity",
      "default": "raw"
    },
    "context_views": {
      "$ref": "#/$defs/ContextViews"
    },
    "source": {
      "$ref": "#/$defs/Source"
    },
    "validity": {
      "$ref": "#/$defs/Validity"
    },
    "support_count": {
      "default": 0,
      "title": "Support Count",
      "type": "integer"
    },
    "contradict_count": {
      "default": 0,
      "title": "Contradict Count",
      "type": "integer"
    },
    "gain_score": {
      "default": 0.0,
      "title": "Gain Score",
      "type": "number"
    },
    "evolved_from": {
      "items": {
        "type": "string"
      },
      "title": "Evolved From",
      "type": "array"
    },
    "superseded_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Superseded By"
    },
    "version": {
      "default": 1,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "id",
    "type",
    "created_at",
    "title",
    "summary"
  ],
  "title": "MemoryItem",
  "type": "object"
}
