# Agent Memory Hub — deployment environment variables
# Copy to .env and fill in your values

# Brain pool data directory
BRAIN_DIR=/data/brain

# LLM configuration (for enrichment + compression)
MEMORY_HUB_NO_MODEL=0
MEMORY_HUB_LLM_MODEL=gpt-4o-mini
MEMORY_HUB_LLM_BASE_URL=
MEMORY_HUB_LLM_API_KEY=

# Dreaming worker interval (seconds)
DREAM_INTERVAL=3600
